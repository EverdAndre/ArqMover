<Window x:Class="ArqMover.Desktop.Interface.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ArqMover"
        Height="700"
        Width="1200"
        MinHeight="640"
        MinWidth="980"
        Background="{StaticResource AppBackgroundBrush}"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="32">
        <Border Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="28">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,28">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="ArqMover" Style="{StaticResource Titulos}"/>
                        <TextBlock Text="Transfira arquivos ou gerencie seus backups."
                                   Style="{StaticResource TextoApoio}"/>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Background="{StaticResource SurfaceMutedBrush}"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="14,10"
                            VerticalAlignment="Center">
                        <Button Content="Logs"
                                        Click="MostrarLogs_Click"
                                        Style="{StaticResource BotaoSecundario}"/>
                    </Border>
                </Grid>

                <Border Grid.Row="1"
                        Background="{StaticResource SurfaceMutedBrush}"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="18"
                        Margin="0,0,0,18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="Modo de operação"
                                   Style="{StaticResource Rotulos}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,28,0"/>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">

                            <RadioButton Content="Transferência de arquivos e pastas"
                                         Checked="Transferencia_Checked"
                                         Style="{StaticResource RotulosRadio}"/>


                            <RadioButton Content="Gestão de backups"
                                         Checked="Backups_Checked"
                                         Style="{StaticResource RotulosRadio}"
                                         IsChecked="True"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="18"
                        Margin="0,0,0,18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Origem" Style="{StaticResource Rotulos}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBox Text="{Binding CaminhoOrigem, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource CampoTexto}"/>
                                <Button Grid.Column="2"
                                        Content="Procurar"
                                        Click="ProcurarOrigem_Click"
                                        Style="{StaticResource BotaoSecundario}"/>
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Destino" Style="{StaticResource Rotulos}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBox Text="{Binding CaminhoDestino, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource CampoTexto}"/>
                                <Button Grid.Column="2"
                                        Content="Procurar"
                                        Click="ProcurarDestino_Click"
                                        Style="{StaticResource BotaoSecundario}"/>
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Column="4" VerticalAlignment="Bottom">
                            <TextBlock Text="Ação" Style="{StaticResource Rotulos}"/>
                            <!-- botao fica desabilitado enquanto a transferencia executa. -->
                            <Button Content="Executar"
                                    IsEnabled="{Binding PodeExecutar}"
                                    Click="IniciarOperacao_Click"
                                    Style="{StaticResource BotaoPrimario}"/>
                            <Button Content="Cancelar"
                                    IsEnabled="{Binding PodeCancelar}"
                                    Click="CancelarOperacao_Click"
                                    Style="{StaticResource BotaoSecundario}"
                                    Margin="0,8,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="3">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{StaticResource SurfaceMutedBrush}"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="14,10"
                            Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Status"
                                        Foreground="{StaticResource TextBrush}"
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Margin="0,0,12,0"/>
                            <TextBlock Grid.Column="1"
                                        Text="{Binding Status}"
                                        Style="{StaticResource TextoApoio}"/>
                            <StackPanel Grid.Column="2"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        Margin="12,0,0,0">
                                <Grid Width="78"
                                      Height="28"
                                      Margin="0,0,10,0"
                                      ClipToBounds="True">
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsExecutando}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>

                                    <Canvas Width="78" Height="28">
                                        <Path Fill="#162033"
                                              Stroke="{StaticResource MutedTextBrush}"
                                              StrokeThickness="1.4"
                                              StrokeLineJoin="Round"
                                              Data="M3,6 L6,3 L18,3 L21,6 L21,22 L3,22 Z"/>
                                        <Path Stroke="{StaticResource MutedTextBrush}"
                                              StrokeThickness="1"
                                              Opacity="0.65"
                                              Data="M6,7 L18,7 M6,20 L18,20"/>
                                        <Ellipse Canvas.Left="8"
                                                 Canvas.Top="10"
                                                 Width="8"
                                                 Height="8"
                                                 Stroke="{StaticResource MutedTextBrush}"
                                                 StrokeThickness="1.2"
                                                 Opacity="0.85"/>
                                        <Ellipse Canvas.Left="11"
                                                 Canvas.Top="13"
                                                 Width="2"
                                                 Height="2"
                                                 Fill="{StaticResource MutedTextBrush}"/>
                                        <Ellipse Canvas.Left="16"
                                                 Canvas.Top="18"
                                                 Width="3"
                                                 Height="3"
                                                 Fill="#48D597"/>

                                        <Path Fill="#162033"
                                              Stroke="{StaticResource MutedTextBrush}"
                                              StrokeThickness="1.4"
                                              StrokeLineJoin="Round"
                                              Data="M59,6 L62,3 L74,3 L77,6 L77,22 L59,22 Z"/>
                                        <Path Stroke="{StaticResource MutedTextBrush}"
                                              StrokeThickness="1"
                                              Opacity="0.65"
                                              Data="M62,7 L74,7 M62,20 L74,20"/>
                                        <Ellipse Canvas.Left="64"
                                                 Canvas.Top="10"
                                                 Width="8"
                                                 Height="8"
                                                 Stroke="{StaticResource MutedTextBrush}"
                                                 StrokeThickness="1.2"
                                                 Opacity="0.85"/>
                                        <Ellipse Canvas.Left="67"
                                                 Canvas.Top="13"
                                                 Width="2"
                                                 Height="2"
                                                 Fill="{StaticResource MutedTextBrush}"/>
                                        <Ellipse Canvas.Left="72"
                                                 Canvas.Top="18"
                                                 Width="3"
                                                 Height="3"
                                                 Fill="#48D597"/>

                                        <Line X1="25"
                                              Y1="14"
                                              X2="53"
                                              Y2="14"
                                              Stroke="{StaticResource MutedTextBrush}"
                                              StrokeThickness="1"
                                              StrokeDashArray="2,2"
                                              Opacity="0.65"/>

                                        <Rectangle Canvas.Left="0"
                                                   Canvas.Top="8"
                                                   Width="10"
                                                   Height="12"
                                                   RadiusX="2"
                                                   RadiusY="2"
                                                   Stroke="{StaticResource MutedTextBrush}"
                                                   StrokeThickness="1.3"
                                                   Fill="{StaticResource SurfaceMutedBrush}">
                                            <Rectangle.RenderTransform>
                                                <TranslateTransform X="24"/>
                                            </Rectangle.RenderTransform>
                                            <Rectangle.Style>
                                                <Style TargetType="Rectangle">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsExecutando}" Value="True">
                                                            <DataTrigger.EnterActions>
                                                                <BeginStoryboard x:Name="AnimacaoTransferenciaArquivo">
                                                                    <Storyboard RepeatBehavior="Forever">
                                                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.X"
                                                                                         From="24"
                                                                                         To="44"
                                                                                         Duration="0:0:0.85"/>
                                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                         From="0.35"
                                                                                         To="1"
                                                                                         AutoReverse="True"
                                                                                         Duration="0:0:0.42"/>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </DataTrigger.EnterActions>
                                                            <DataTrigger.ExitActions>
                                                                <StopStoryboard BeginStoryboardName="AnimacaoTransferenciaArquivo"/>
                                                            </DataTrigger.ExitActions>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Rectangle.Style>
                                        </Rectangle>
                                    </Canvas>
                                </Grid>
                                <ProgressBar Minimum="0"
                                             Maximum="100"
                                             Value="{Binding Progresso}"
                                             Style="{StaticResource BarraProgresso}"/>
                                <TextBlock Text="{Binding Progresso, StringFormat={}{0}%}"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           MinWidth="36"
                                           Margin="10,0,0,0"
                                           VerticalAlignment="Center"
                                           TextAlignment="Right"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            Background="{StaticResource LogBackgroundBrush}"
                            BorderBrush="#223049"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Background="#162033"
                                    CornerRadius="9,9,0,0"
                                    Padding="14,10">
                                <TextBlock Text="Log"
                                           Foreground="{StaticResource LogTextBrush}"
                                           FontSize="14"
                                           FontWeight="SemiBold"/>
                            </Border>

                            <TextBox Grid.Row="1"
                                     Text="{Binding Log}"
                                     Background="{StaticResource LogBackgroundBrush}"
                                     Foreground="{StaticResource LogTextBrush}"
                                     FontFamily="Consolas"
                                     FontSize="14"
                                     Padding="14"
                                     BorderThickness="0"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     IsReadOnly="True"/>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
